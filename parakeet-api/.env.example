# Parakeet API Configuration Example
# Copy this to .env and fill in the values

# Server Settings
# ---------------
# SERVER__HOST=0.0.0.0
# SERVER__PORT=8816
# SERVER__DEBUG=false
# SERVER__API_KEY=your-secret-api-key

# STT (Speech to Text) Settings
# -----------------------------
# Default models_dir depends on platform:
# Linux: ~/.local/share/parakeet-api/models
# macOS: ~/Library/Application Support/parakeet-api/models
# To use a local directory (e.g., during development):
# STT__MODELS_DIR=models

# For Sherpa-ONNX
# STT__SHERPA__PROVIDER=cpu
# STT__SHERPA__NUM_THREADS=2
# STT__SHERPA__MODEL_ID=sherpa-onnx-nemo-parakeet-tdt-0.6b-v3-int8

# For Japanese (Sherpa):
# STT__SHERPA__MODEL_ID=sherpa-onnx-nemo-parakeet-tdt_ctc-0.6b-ja-35000-int8

# For MLX (Apple Silicon)
# STT__MLX__MODEL_ID=mlx-community/parakeet-tdt-0.6b-v3

# For Japanese (MLX):
# STT__MLX__MODEL_ID=mlx-community/parakeet-tdt_ctc-0.6b-ja

# Advanced STT Settings
# ---------------------
# Disable FFmpeg/pydub conversion logic and assume input is 16kHz mono PCM.
# STT__DISABLE_CONVERSION=false

# Hotwords / Contextual Biasing (Sherpa-ONNX Transducer models only)
# ----------------------------------------------------------------
# Default boosting score per token (default: 1.5)
# STT__SHERPA__HOTWORDS__DEFAULT_SCORE=1.5

# Number of hotword recognizers to cache (default: 1, 0=no cache, each ~670MB)
# STT__SHERPA__HOTWORDS__CACHE_SIZE=1
